---
import ClusterStatus from "./ClusterStatus";
---

<header>
    <nav>
        <ul>
            <li>
                <a href="https://fh-swf.de"
                    ><img
                        class="logo"
                        src="/fh-swf.svg"
                        alt="Logo der Fachhochschule Südwestfalen"
                        title="Fachhochschule Südwestfalen"
                    /></a
                >
            </li>
            <li><a href="/">Home</a></li>
            <li>
                <a href="https://openai.ki.fh-swf.de" target="_blank">K!mpuls</a
                >
            </li>
            <li>
                <a
                    href="https://www.ki.fh-swf.de/new-jupyterhub"
                    target="_blank">JupyterHub</a
                >
            </li>
            <li><a href="/dokumentation">Dokumentation</a></li>
            <li><a href="/faq">FAQ</a></li>
            <li class="system-status">
                <a
                    class="system-status__link"
                    href="https://status.fh-swf.cloud/"
                    target="_blank"
                    rel="noreferrer"
                >
                    <span class="system-status__title">Status</span>
                    <span class="system-status__badges">
                        <span
                            class="system-status__service"
                            data-status-group="jupyterhub"
                        >
                            <span
                                class="system-status__dot"
                                aria-hidden="true"></span>
                            <span>JupyterHub</span>
                            <span class="sr-only">Status wird geladen</span>
                        </span>
                        <span
                            class="system-status__service"
                            data-status-group="openai-ui"
                        >
                            <span
                                class="system-status__dot"
                                aria-hidden="true"></span>
                            <span>K!mpuls</span>
                            <span class="sr-only">Status wird geladen</span>
                        </span>
                        <span
                            class="system-status__service"
                            data-status-group="keycloak"
                        >
                            <span
                                class="system-status__dot"
                                aria-hidden="true"></span>
                            <span>Keycloak</span>
                            <span class="sr-only">Status wird geladen</span>
                        </span>
                    </span>
                </a>
            </li>
        </ul>
    </nav>
    <script src="/system-status.js" defer></script>
</header>

<style>
    header {
        background-color: hsl(0, 0%, 100%);
        color: black;
        padding: 20px;
        margin: 0;
        text-align: center;
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 1rem;
    }

    img.logo {
        height: 40px;
    }

    ul {
        display: flex;
        align-items: center;
        height: 100%;
        gap: clamp(1rem, 3vw, 5ex);
        list-style-type: none;
        padding: 10px;
        overflow: hidden;
        flex-wrap: wrap;
        justify-content: center;
    }

    .system-status {
        margin-left: auto;
    }

    .system-status__link {
        align-items: center;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 8px;
        display: flex;
        gap: 0.75rem;
        padding: 0.45rem 0.6rem;
        text-decoration: none;
    }

    .system-status__title {
        color: var(--theme-text);
        font-size: 0.95rem;
        font-weight: 700;
    }

    .system-status__badges {
        display: flex;
        gap: 0.5rem;
    }

    .system-status__service {
        align-items: center;
        display: flex;
        gap: 0.35rem;
    }

    .system-status__service span {
        color: var(--theme-text-light);
        font-size: 0.78rem;
        font-weight: 700;
    }

    .system-status__dot {
        background: #9ca3af;
        border-radius: 999px;
        box-shadow: 0 0 0 3px rgb(156 163 175 / 0.16);
        display: inline-block;
        flex: 0 0 auto;
        height: 0.65rem;
        width: 0.65rem;
    }

    .system-status__service[data-status="operational"] .system-status__dot {
        background: #15803d;
        box-shadow: 0 0 0 3px rgb(21 128 61 / 0.18);
    }

    .system-status__service[data-status="degraded"] .system-status__dot {
        background: #ca8a04;
        box-shadow: 0 0 0 3px rgb(202 138 4 / 0.2);
    }

    .system-status__service[data-status="outage"] .system-status__dot {
        background: #dc2626;
        box-shadow: 0 0 0 3px rgb(220 38 38 / 0.18);
    }

    .sr-only {
        border: 0;
        clip: rect(0, 0, 0, 0);
        height: 1px;
        margin: -1px;
        overflow: hidden;
        padding: 0;
        position: absolute;
        white-space: nowrap;
        width: 1px;
    }

    @media (max-width: 960px) {
        .system-status {
            margin-left: 0;
            width: 100%;
        }

        .system-status__link {
            justify-content: center;
        }
    }

    @media (max-width: 640px) {
        .system-status__link,
        .system-status__badges {
            align-items: stretch;
            flex-direction: column;
        }

        .system-status__service {
            justify-content: space-between;
        }
    }
</style>
